{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vite/client", "@tdesign-vue-next/chat/global"]
  },
  "include": [
    "pages/**/*.ts",
    "pages/**/*.d.ts",
    "pages/**/*.vue",
    "vite.config.ts",
    "components.d.ts",
    "auto-imports.d.ts"
  ],
  "exclude": ["dist"]
}
