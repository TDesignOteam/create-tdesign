{
  "name": "create-tdesign",
  "version": "0.1.0",
  "packageManager": "pnpm@11.0.9",
  "description": "Scaffold TDesign projects with Vite or Rspack.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-tdesign": "index.js"
  },
  "files": [
    "index.js",
    "dist",
    "templates"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tdesign",
    "cli",
    "scaffold",
    "vite",
    "rspack"
  ],
  
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@types/node": "^25.6.2",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
