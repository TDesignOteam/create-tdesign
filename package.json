{
  "name": "create-tdesign",
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.1",
  "description": "Scaffold TDesign projects with Vite, Rspack, or Vike.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-tdesign": "index.js"
  },
  "files": [
    "index.js",
    "dist",
    "templates"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TDesignOteam/create-tdesign.git"
  },
  "homepage": "https://github.com/TDesignOteam/create-tdesign/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/TDesignOteam/create-tdesign/issues"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tdesign",
    "cli",
    "scaffold",
    "vite",
    "rspack",
    "vike"
  ],
  
  "devDependencies": {
    "@clack/prompts": "^1.4.0",
    "@types/node": "^25.7.0",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
